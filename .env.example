# API
API_V1_STR=/api/v1
PROJECT_NAME=Strategic Planning System
VERSION=1.0.0

# Seguridad JWT
SECRET_KEY=tu_clave_secreta_aqui_cambiar_en_produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
TOKEN_TYPE=Bearer

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# DataMAIN
# Railway/Producción: usa Postgres (valor inyectado por Railway)
# DATAMAIN_URL=${{Postgres.DATAMAIN_URL}}
# Local/dev fallback:
DATAMAIN_URL=sqlite:///./strategic_planning_development.db
SQLITE_DB_PATH=strategic_planning_development.db
HOST_DATAMAIN_MAP=avancoop.org=avandbcoop.db,www.avancoop.org=avandbcoop.db,cajapolotitlan.circulocooperativo.com=polobdtittlan.db
# Alternativa JSON:
# HOST_DATAMAIN_MAP_JSON={"avancoop.org":"avandbcoop.db","www.avancoop.org":"avandbcoop.db","cajapolotitlan.circulocooperativo.com":"polobdtittlan.db"}
UPDATE_SOURCE_MAP=avancoop.org=https://actualizaciones.circulocooperativo.com/avancoop/manifest.json,www.avancoop.org=https://actualizaciones.circulocooperativo.com/avancoop/manifest.json,cajapolotitlan.circulocooperativo.com=https://actualizaciones.circulocooperativo.com/polotitlan/manifest.json,sipet.circulocooperativo.com=https://actualizaciones.circulocooperativo.com/sipet/manifest.json
UPDATE_CHANNEL_MAP=avancoop.org=avancoop,www.avancoop.org=avancoop,cajapolotitlan.circulocooperativo.com=polotitlan,sipet.circulocooperativo.com=railway
UPDATE_STRATEGY_MAP=avancoop.org=git-pull,www.avancoop.org=git-pull,cajapolotitlan.circulocooperativo.com=git-pull,sipet.circulocooperativo.com=manual
AUTO_UPDATE_ENABLED=true
UPDATE_CHECK_TIMEOUT_SECONDS=6
DATAMAIN_POOL_SIZE=20
DATAMAIN_MAX_OVERFLOW=40

# Email (opcional, para recuperación de contraseña)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_password_app
EMAILS_FROM_EMAIL=noreply@strategicplan.com
EMAILS_FROM_NAME=Strategic Planning System

# Redis (opcional, para tokens blacklist)
REDIS_URL=redis://localhost:6379/0

# Aplicación
DEBUG=true
ENVIRONMENT=development
APP_ENV=development
AUTH_COOKIE_SECRET=definir_una_clave_larga_y_unica
SENSITIVE_DATA_SECRET=definir_una_clave_larga_y_unica
COOKIE_SECURE=false
SESSION_MAX_AGE_SECONDS=28800
ALLOW_LEGACY_PLAINTEXT_PASSWORDS=false
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=7
IDENTITY_UPLOAD_MAX_BYTES=5242880
RUNTIME_STORE_DIR=fastapi_modulo/runtime_store/development
PLANTILLAS_STORE_PATH=
DATOS_PRELIMINARES_STORE_PATH=
REGIONES_STORE_PATH=
SUCURSALES_STORE_PATH=
ENABLE_API_DOCS=true
HEALTH_INCLUDE_DETAILS=false
CSRF_PROTECTION_ENABLED=true
AUTHORITIES_TOTP_SECRET=
TOTP_PERIOD_SECONDS=30
TOTP_ALLOWED_DRIFT_STEPS=1

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Password policies
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true
